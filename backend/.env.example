# Postgres.app (macOS): replace YOUR_USERNAME with your macOS username (run `whoami`)
DATABASE_URL=postgresql+asyncpg://YOUR_USERNAME@localhost/artemarket
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins (no trailing slash)
# Dev default: http://localhost:5173
# Production example: https://artemarket.web.app,https://artemarket.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
